# LLM provider: ollama | openai | deepseek | openai_compatible
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0

# Paths
DATA_DIR=data
DEFAULT_WORKSPACE_ID=default
KNOWLEDGE_SCOPE=workspace_documents
PDF_PARSER_BACKEND=docling
DOCLING_ARTIFACTS_PATH=
DOCLING_DO_OCR=false
DOCLING_DO_FORMULA_ENRICHMENT=false

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# Reranker
RERANK_PROVIDER=siliconflow
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
RERANK_TOP_N=6
RERANK_MAX_CANDIDATES=24

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://openrouter.fans/v1

# OpenAI-compatible APIs (vLLM, gateways, etc.)
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=

# Retrieval / graph defaults
DEFAULT_SEARCH_LIMIT=6
MAX_TOOL_CALLS=8
MAX_ITERATIONS=10
GRAPH_RECURSION_LIMIT=50
BASE_TOKEN_THRESHOLD=2000
TOKEN_GROWTH_FACTOR=0.9
CHILD_CHUNK_SIZE=500
CHILD_CHUNK_OVERLAP=100
MIN_PARENT_SIZE=2000
MAX_PARENT_SIZE=4000
FORMULA_REFINEMENT_MAX_PAGES=0
FORMULA_REFINEMENT_TIMEOUT=180

# Langfuse Observability (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
